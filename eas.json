{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://simplyrich-backend.onrender.com",
        "EXPO_PUBLIC_SUPPORT_EMAIL": "support@simplyrich.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
